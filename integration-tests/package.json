{
  "name": "privatepdf-integration-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright integration tests for PrivatePDF (BentoPDF)",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:popular": "npx playwright test tests/popular/",
    "test:edit": "npx playwright test tests/edit-annotate/",
    "test:convert-to": "npx playwright test tests/convert-to-pdf/",
    "test:convert-from": "npx playwright test tests/convert-from-pdf/",
    "test:organize": "npx playwright test tests/organize-manage/",
    "test:optimize": "npx playwright test tests/optimize-repair/",
    "test:secure": "npx playwright test tests/secure/",
    "test:report": "npx playwright show-report",
    "generate-fixtures": "node helpers/generate-all-fixtures.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "archiver": "^7.0.1",
    "pdf-lib": "^1.17.1"
  }
}
